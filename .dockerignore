# Build context is limited to core/ and feature-council/ (each a uv workspace
# member installed by path). Everything else is excluded to keep context
# minimal and images lean.
.git
.github
.venv
**/__pycache__
.pytest_cache
.ruff_cache
docs
infra
node_modules
dist
local_state
*.egg-info
.env
# Tests are never copied into images (members are installed by path; wheels ship
# src/dsf only). Exclude every member's tests/ tree, not just a root one.
**/tests
# Non-build artefacts
config
Makefile
*.md