      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('agentResourceGroup')), 'Microsoft.Resources/deployments', format('sre-agent-{0}', parameters('product'))), '2025-04-01').outputs.agentEndpoint.value]"
    },
    "agentPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Object (principal) ID of the SRE agent user-assigned managed identity."
      },
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('agentResourceGroup')), 'Microsoft.Resources/deployments', format('sre-agent-{0}', parameters('product'))), '2025-04-01').outputs.principalId.value]"
    }
  }
}