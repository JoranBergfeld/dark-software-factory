                "dataSource": "[parameters('logAnalyticsId')]",
                "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName')))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName')))]",
                "[resourceId('Microsoft.App/agents', parameters('agentName'))]"
              ]
            },
            {
              "type": "Microsoft.App/agents/connectors",
              "apiVersion": "2026-01-01",
              "name": "[format('{0}/{1}', parameters('agentName'), 'appinsights')]",
              "properties": {
                "dataConnectorType": "AppInsights",
                "dataSource": "[parameters('appInsightsId')]",
                "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName')))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName')))]",
                "[resourceId('Microsoft.App/agents', parameters('agentName'))]"
              ]
            }
          ],
          "outputs": {
            "principalId": {
              "type": "string",
              "metadata": {
                "description": "Object (principal) ID of the SRE agent UAMI — used for RBAC assignments."
              },
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName'))), '2023-01-31').principalId]"
            },
            "agentId": {
              "type": "string",
              "metadata": {
                "description": "ARM resource id of the SRE agent."
              },
              "value": "[resourceId('Microsoft.App/agents', parameters('agentName'))]"
            },
            "agentEndpoint": {
              "type": "string",
              "metadata": {
                "description": "Data-plane endpoint URL for the SRE agent."
              },
              "value": "[reference(resourceId('Microsoft.App/agents', parameters('agentName')), '2026-01-01').agentEndpoint]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('agentResourceGroup'))]"
      ]
    },
    {
      "copy": {
        "name": "rgRoles",
        "count": "[length(parameters('targetResourceGroups'))]"
