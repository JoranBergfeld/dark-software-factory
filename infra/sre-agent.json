      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "principalId": {
            "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('agentResourceGroup')), 'Microsoft.Resources/deployments', format('sre-agent-{0}', parameters('product'))), '2025-04-01').outputs.principalId.value]"
          },
          "agentName": {
            "value": "[parameters('agentName')]"
          },
          "roleId": {
            "value": "[variables('monitoringContributorRoleId')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "17508780024249043423"
            }
          },
          "parameters": {
            "principalId": {
              "type": "string",
              "metadata": {
                "description": "Principal (object) id of the SRE agent user-assigned managed identity."
              }
            },
            "agentName": {
              "type": "string",
              "metadata": {
                "description": "SRE Agent resource name — used to derive a stable role-assignment name."
              }
            },
            "roleId": {
              "type": "string",
              "metadata": {
                "description": "Built-in role definition GUID to assign."
