                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', parameters('roleId'))]"
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('agentResourceGroup')), 'Microsoft.Resources/deployments', format('sre-agent-{0}', parameters('product')))]"
      ]
    }
  ],
  "outputs": {
    "agentId": {
      "type": "string",
      "metadata": {
        "description": "ARM resource id of the SRE agent."
      },
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('agentResourceGroup')), 'Microsoft.Resources/deployments', format('sre-agent-{0}', parameters('product'))), '2025-04-01').outputs.agentId.value]"
    },
    "agentEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Data-plane endpoint URL (https://<name>.<location>.azuresre.ai)."
