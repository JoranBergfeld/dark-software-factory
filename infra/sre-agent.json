{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "1146723739709736781"
    }
  },
  "parameters": {
    "product": {
      "type": "string",
      "metadata": {
        "description": "Short product key (e.g. \"microbi\"). Used to name the agent and its RG."
      }
    },
    "agentName": {
      "type": "string",
      "metadata": {
        "description": "Full SRE Agent resource name (e.g. \"dsf-sre-microbi\")."
      }
    },
    "sreAgentLocation": {
      "type": "string",
      "defaultValue": "swedencentral",
      "allowedValues": [
        "swedencentral",
        "eastus2",
        "australiaeast"
      ],
      "metadata": {
        "description": "Azure region for the SRE Agent. Must be swedencentral, eastus2, or australiaeast."
      }
    },
    "agentResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Name of the dedicated resource group that will host the SRE agent."
      }
    },
    "targetResourceGroups": {
      "type": "array",
      "metadata": {
        "description": "Resource groups the agent monitors (factory RG + any monitored-app RGs)."
      }
    },
    "appInsightsId": {
      "type": "string",
      "metadata": {
        "description": "Application Insights resource id (consumed by the SRE agent connector + RBAC)."
      }
    },
    "logAnalyticsId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace resource id (consumed by the SRE agent connector + RBAC)."
      }
    },
    "appInsightsAppId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Application Insights \"Application ID\" GUID (shown in portal Overview, not the ARM resource id). Optional — leave empty to skip agent-side App Insights log configuration."
      }
    },
    "appInsightsConnectionString": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Application Insights connection string (instrumentation key URI). Optional — leave empty to skip agent-side App Insights log configuration."
      }
    },
    "permissionLevel": {
      "type": "string",
      "defaultValue": "Reader",
      "allowedValues": [
        "Reader",
        "Privileged"
      ],
      "metadata": {
        "description": "Permission level granted to the SRE agent. \"Reader\" is the default and only wired level.\n\"Privileged\" is accepted by the deploy command but additional role wiring is future work\n(the RBAC assignments below only cover the Reader surface regardless of this value).\n"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "dark-software-factory",
        "component": "sre-agent"
      },
      "metadata": {
        "description": "Tags applied to all resources in this deployment."
      }
    }
  },
  "variables": {
    "monitoringContributorRoleId": "749f88d5-cbae-40b8-bcfc-e573ddc772fa"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-03-01",
      "name": "[parameters('agentResourceGroup')]",
      "location": "[parameters('sreAgentLocation')]",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('sre-agent-{0}', parameters('product'))]",
      "resourceGroup": "[parameters('agentResourceGroup')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "agentName": {
            "value": "[parameters('agentName')]"
          },
          "location": {
            "value": "[parameters('sreAgentLocation')]"
          },
          "targetResourceGroups": {
            "value": "[parameters('targetResourceGroups')]"
          },
          "appInsightsId": {
            "value": "[parameters('appInsightsId')]"
          },
          "appInsightsAppId": {
            "value": "[parameters('appInsightsAppId')]"
          },
          "appInsightsConnectionString": {
            "value": "[parameters('appInsightsConnectionString')]"
          },
          "logAnalyticsId": {
            "value": "[parameters('logAnalyticsId')]"
          },
          "permissionLevel": {
            "value": "[parameters('permissionLevel')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "6546496901142834339"
            }
          },
          "parameters": {
            "agentName": {
              "type": "string",
              "metadata": {
                "description": "SRE Agent resource name."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region. Must be one of swedencentral, eastus2, australiaeast."
              }
            },
            "targetResourceGroups": {
              "type": "array",
              "metadata": {
                "description": "Resource groups the agent monitors; wired into knowledgeGraphConfiguration.managedResources."
              }
            },
            "appInsightsId": {
              "type": "string",
              "metadata": {
                "description": "Application Insights resource id (for the log connector)."
              }
            },
            "appInsightsAppId": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Application Insights app id (the GUID from portal, not the resource id). Optional — leave empty to skip agent-side App Insights log configuration."
              }
            },
            "appInsightsConnectionString": {
              "type": "securestring",
              "defaultValue": "",
              "metadata": {
                "description": "Application Insights connection string (sensitive). Optional — leave empty to skip agent-side App Insights log configuration."
              }
            },
            "logAnalyticsId": {
              "type": "string",
              "metadata": {
                "description": "Log Analytics workspace resource id."
              }
            },
            "permissionLevel": {
              "type": "string",
              "defaultValue": "Reader",
              "allowedValues": [
                "Reader",
                "Privileged"
              ],
              "metadata": {
                "description": "Permission level; only \"Reader\" RBAC is wired today. \"Privileged\" accepted for future use."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Tags applied to the resources."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
