              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]"
            },
            {
              "type": "Microsoft.App/agents",
              "apiVersion": "2026-01-01",
              "name": "[parameters('agentName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName'))))]": {}
                }
              },
              "properties": {
                "upgradeChannel": "Stable",
                "actionConfiguration": {
                  "accessLevel": "Low",
                  "mode": "ReadOnly",
                  "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName')))]"
                },
                "knowledgeGraphConfiguration": {
                  "copy": [
                    {
                      "name": "managedResources",
                      "count": "[length(parameters('targetResourceGroups'))]",
                      "input": "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('targetResourceGroups')[copyIndex('managedResources')])]"
                    }
                  ],
                  "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName')))]"
                },
                "logConfiguration": "[if(empty(parameters('appInsightsAppId')), null(), createObject('applicationInsightsConfiguration', createObject('appId', parameters('appInsightsAppId'), 'connectionString', parameters('appInsightsConnectionString'))))]",
                "defaultModel": {
                  "provider": "MicrosoftFoundry",
                  "name": "Automatic"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('agentName')))]"
              ]
            },
            {
              "type": "Microsoft.App/agents/connectors",
              "apiVersion": "2026-01-01",
              "name": "[format('{0}/{1}', parameters('agentName'), 'loganalytics')]",
