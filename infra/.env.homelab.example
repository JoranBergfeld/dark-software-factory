# .env.homelab.example
# Copy to infra/.env.homelab and fill in, then:
#   docker compose -f infra/compose.homelab.yml --env-file infra/.env.homelab up -d
#
# Secrets stay local to the homelab host; nothing is committed.

# A2A bearer token the cloud orchestrator presents when calling the Grafana
# agent. Must match the token the orchestrator reads from Key Vault.
A2A_BEARER_TOKEN=

# Cloud platform endpoints (outbound use from the homelab agent).
AZURE_APPCONFIG_ENDPOINT=
AZURE_KEYVAULT_URI=
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Local Grafana the agent queries.
GRAFANA_URL=http://grafana.local:3000
GRAFANA_TOKEN=

# --- Tunnel: set the one matching your chosen sidecar in compose.homelab.yml ---
# Option A: Cloudflare Tunnel token (from `cloudflared tunnel token <name>`).
TUNNEL_TOKEN=
# Option B: Tailscale auth key (if using the tailscale sidecar instead).
TS_AUTHKEY=
