# DSF runtime mode: local (in-memory fakes, no cloud) | azure
DSF_MODE=local

# Global dry-run: investigate but never file issues (also toggleable in Control Center)
DSF_DRY_RUN=true

# --- Azure (only used when DSF_MODE=azure; never required for local dry-run) ---
AZURE_COSMOS_ENDPOINT=
AZURE_APPCONFIG_ENDPOINT=
AZURE_KEYVAULT_URI=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
FOUNDRY_PROJECT_ENDPOINT=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
A2A_BEARER_TOKEN=
