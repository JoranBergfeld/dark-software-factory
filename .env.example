# Global dry-run: investigate but never file issues (also toggleable in Control Center)
DSF_DRY_RUN=true

# --- Live source backends (only used when DSF_MODE=live) ---

# Sentry. Two ways to go live (MCP preferred when SENTRY_MCP_URL is set):
#  (a) MCP server (e.g. self-hosted): SENTRY_MCP_URL + optional SENTRY_MCP_TOKEN
SENTRY_MCP_URL=
SENTRY_MCP_TOKEN=
#  (b) Sentry REST API directly: SENTRY_AUTH_TOKEN (+ base url)
SENTRY_AUTH_TOKEN=
SENTRY_BASE_URL=https://sentry.io
# Org/project default the run scope for either path:
SENTRY_ORG=
SENTRY_PROJECT=

# Grafana (HTTP API). Service-account token; URL is your Grafana base URL.
GRAFANA_URL=
GRAFANA_TOKEN=

# FoundryIQ via Azure AI Search (the knowledge index behind FoundryIQ).
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=
AZURE_SEARCH_KEY=
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_REF_FIELD=url

# WebIQ web search. Default provider: Tavily (https://tavily.com).
WEBIQ_PROVIDER=tavily
TAVILY_API_KEY=

# --- Azure platform (only used when running the full line against deployed infra) ---
AZURE_COSMOS_ENDPOINT=
AZURE_APPCONFIG_ENDPOINT=
AZURE_KEYVAULT_URI=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
# Embeddings deployment for semantic deduplication (e.g. text-embedding-3-small).
# When set (with AZURE_OPENAI_ENDPOINT), query_similar ranks by embedding cosine
# similarity instead of token overlap.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
FOUNDRY_PROJECT_ENDPOINT=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
A2A_BEARER_TOKEN=
